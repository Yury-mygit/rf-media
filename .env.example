SERVICE_NAME=media-dev
VERSION=0.1.0
LOG_LEVEL=info

# Postgres (asyncpg). Внутри shared docker network — host=db_shared, port=5432.
DATABASE_URL=postgresql+asyncpg://media_dev:<password>@db_shared:5432/media_dev

# Storage
STORAGE_ROOT=/srv/storage
MAX_UPLOAD_BYTES=10485760
ALLOWED_MIME_PREFIXES=image/,audio/,video/,application/pdf,application/zip

# CORS: список origin'ов, которые могут upload'ить.
CORS_ALLOW_ORIGINS=https://board.dev.raftforge.art,https://notes.dev.raftforge.art

# Orphan GC (pull-модель). Consumers — `name=internal_url;...`
MEDIA_CONSUMERS=board=http://board_dev_app:8000/api/v1/media-refs
MEDIA_GC_TOKEN=<shared secret across media and consumer .env's>
MEDIA_GC_GRACE_DAYS=7
MEDIA_GC_ENABLED=true
MEDIA_GC_CRON_HOUR=3
